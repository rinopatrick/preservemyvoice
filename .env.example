# PreserveMyVoice - Environment Configuration
# Copy this file to .env and fill in your values

# Application
APP_NAME=PreserveMyVoice
APP_VERSION=0.1.0
DEBUG=false

# Database
DATABASE_URL=sqlite:///./preservemyvoice.db

# File Storage
UPLOAD_DIR=./uploads
MODELS_DIR=./voice_models
MAX_RECORDING_SIZE=52428800

# Audio Processing
SAMPLE_RATE=22050
N_FFT=2048
HOP_LENGTH=512
N_MELS=80

# Server
HOST=0.0.0.0
PORT=8000
